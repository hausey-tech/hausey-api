{
  "name": "hausey-api",
  "version": "1.0.0",
  "description": "Hausey API REST",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "dev:server": "ts-node-dev --inspect --transpile-only --ignore node_modules src/shared/server.ts",
    "typeorm": "ts-node-dev -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:create": "cross-env typeorm-ts-node-commonjs migration:create ./src/shared/database/migrations/$name",
    "migration:generate": "cross-env typeorm-ts-node-commonjs migration:generate -d ./src/shared/database ./src/shared/database/migrations/$name",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d ./src/shared/database",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d ./src/shared/database"
  },
  "author": "<any/>",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "celebrate": "^15.0.1",
    "cpf-cnpj-validator": "^1.0.3",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "pg": "^8.8.0",
    "reflect-metadata": "^0.1.13",
    "tsyringe": "^4.7.0",
    "typeorm": "^0.3.10"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/express": "^4.17.14",
    "@typescript-eslint/eslint-plugin": "^5.42.0",
    "@typescript-eslint/parser": "^5.42.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.26.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-import-resolver-typescript": "^3.5.2",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-prettier": "^4.2.1",
    "prettier": "^2.7.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^4.8.4"
  }
}
