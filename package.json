{
  "name": "hausey-api",
  "version": "1.0.0",
  "description": "Hausey API REST",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/shared/server.js",
    "dev:server": "ts-node-dev -r tsconfig-paths/register --inspect --transpile-only --ignore node_modules src/shared/server.ts",
    "dev:docker": "docker-compose up -d",
    "typeorm": "ts-node-dev -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:create": "cross-env yarn typeorm migration:create ./src/shared/typeorm/migrations/$name",
    "migration:generate": "cross-env yarn typeorm migration:generate -d ./src/shared/typeorm ./src/shared/typeorm/migrations/$name",
    "migration:run": "yarn typeorm migration:run -d ./src/shared/typeorm",
    "migration:revert": "yarn typeorm migration:revert -d ./src/shared/typeorm",
    "prepare": "husky install",
    "pre-commit": "yarn lint-staged"
  },
  "author": "<any/>",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.238.0",
    "@getbrevo/brevo": "^3.0.1",
    "axios": "^1.2.1",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "celebrate": "^15.0.1",
    "csv-parse": "^5.6.0",
    "csv-parser": "^3.2.0",
    "date-fns": "^2.29.3",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "firebase-admin": "^12.0.0",
    "jsonwebtoken": "^8.5.1",
    "moment-timezone": "^0.5.47",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.8.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "^0.1.13",
    "stripe": "^11.10.0",
    "swagger-ui-express": "^4.6.0",
    "tsyringe": "^4.7.0",
    "twilio": "^3.84.0",
    "typeorm": "^0.3.10",
    "typeorm-naming-strategies": "^4.1.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/express": "^4.17.14",
    "@types/jsonwebtoken": "^8.5.9",
    "@types/multer": "^1.4.7",
    "@types/swagger-ui-express": "^4.1.3",
    "@types/uuid": "^8.3.4",
    "@typescript-eslint/eslint-plugin": "^5.42.0",
    "@typescript-eslint/parser": "^5.42.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.26.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-import-resolver-typescript": "^3.5.2",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-prettier": "^4.2.1",
    "git-commit-msg-linter": "^4.4.0",
    "husky": "^8.0.2",
    "lint-staged": "^13.1.0",
    "prettier": "^2.7.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.1.0",
    "typescript": "^4.8.4"
  }
}
